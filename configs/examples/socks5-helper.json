{
  "schema_version": 1,
  "node": "socks5-client",
  "role": "client",
  "peer": "socks5-exit",
  "paths": [
    {
      "name": "path-a",
      "interface": "lo",
      "transport_bind": "127.0.0.1:55220",
      "transport_remote": "127.0.0.1:55221"
    }
  ],
  "services": [
    {
      "name": "socks5-stream",
      "listen": "127.0.0.1:55190",
      "target": "127.0.0.1:56190"
    }
  ],
  "helpers": {
    "socks5": {
      "enabled": true,
      "service": "socks5-stream",
      "listen": "127.0.0.1:1080",
      "allow_hosts": [
        "example.com"
      ],
      "allow_ports": [
        443
      ]
    }
  }
}
