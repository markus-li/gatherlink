{
  "schema_version": 1,
  "name": "local-three-path",
  "scenario": "local-multi-path",
  "description": "Three unprivileged Gatherlink lab paths for scheduler and path-behavior testing.",
  "security": {
    "mode": "none"
  },
  "runtime_dir": ".lab/local-three-path",
  "nodes": [
    {
      "name": "client",
      "role": "client",
      "config_path": "configs/examples/minimal-client.json",
      "run_as": "current-user"
    },
    {
      "name": "server",
      "role": "server",
      "config_path": "configs/examples/minimal-server.json",
      "run_as": "current-user"
    }
  ],
  "paths": [
    {
      "name": "path-a",
      "family": "ipv4",
      "client_address": "10.81.1.1",
      "server_address": "10.81.1.2",
      "subnet": "10.81.1.0/30",
      "default_max_speed": "300mbit",
      "shape": {
        "rate": "50mbit"
      }
    },
    {
      "name": "path-b",
      "family": "ipv4",
      "client_address": "10.81.2.1",
      "server_address": "10.81.2.2",
      "subnet": "10.81.2.0/30",
      "default_max_speed": "500mbit",
      "shape": {
        "rate": "50mbit"
      }
    },
    {
      "name": "path-c",
      "family": "ipv4",
      "client_address": "10.81.3.1",
      "server_address": "10.81.3.2",
      "subnet": "10.81.3.0/30",
      "default_max_speed": "700mbit",
      "shape": {
        "rate": "50mbit"
      }
    }
  ],
  "traffic": {
    "generator": "iperf3",
    "listen": "127.0.0.1:55280",
    "target": "127.0.0.1:51920",
    "duration_seconds": 10,
    "bandwidth": "12mbit"
  },
  "reorder_policies": [
    {
      "node_pair": "client<->server",
      "max_hold": "150ms"
    }
  ],
  "profiles": {
    "clean": {
      "path-a": {
        "state": "up"
      },
      "path-b": {
        "state": "up"
      },
      "path-c": {
        "state": "up"
      }
    },
    "path-a-down": {
      "path-a": {
        "state": "down"
      }
    },
    "path-c-blackhole": {
      "path-c": {
        "blackhole": true
      }
    }
  },
  "network_modes": {
    "clean-50mbit": {
      "description": "Restore all paths to clean 50mbit links.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "50mbit"
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "50mbit"
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "50mbit"
          }
        }
      ]
    },
    "acceptance-300-500-700": {
      "description": "Hard three-path acceptance profile: 300/500/700mbit with pressure intended around 1.55gbit.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "300mbit",
            "limit": 131072
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "500mbit",
            "limit": 131072
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "700mbit",
            "limit": 131072
          }
        }
      ]
    },
    "acceptance-uneven-high": {
      "description": "Higher uneven local-lab profile for scheduler scaling: 600/900/1300mbit with pressure intended around 2.9gbit.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "600mbit",
            "limit": 4096
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "900mbit",
            "limit": 4096
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "1300mbit",
            "limit": 4096
          }
        }
      ]
    },
    "realworld-fiber-plus-5g": {
      "description": "1gbit home fiber facsimile where useful throughput is closer to 800mbit plus two 5G-style links; useful delivery pressure intended around 950mbit.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "800mbit",
            "delay": "12ms",
            "jitter": "3ms",
            "limit": 4096
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "160mbit",
            "delay": "45ms",
            "jitter": "15ms",
            "loss": "0.2%",
            "limit": 2048
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "85mbit",
            "delay": "70ms",
            "jitter": "25ms",
            "loss": "0.5%",
            "limit": 2048
          }
        }
      ]
    },
    "realworld-starlink-plus-5g": {
      "description": "Starlink plus one active 5G router and one weak standby link; useful delivery pressure intended around 250mbit.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "180mbit",
            "delay": "45ms",
            "jitter": "25ms",
            "loss": "0.3%",
            "limit": 2048
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "120mbit",
            "delay": "55ms",
            "jitter": "20ms",
            "loss": "0.6%",
            "limit": 2048
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "15mbit",
            "delay": "95ms",
            "jitter": "35ms",
            "loss": "1%",
            "limit": 512
          }
        }
      ]
    },
    "realworld-starlink-plus-2x5g": {
      "description": "Starlink plus two 5G routers with different latency and jitter; useful delivery pressure intended around 350mbit.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "180mbit",
            "delay": "45ms",
            "jitter": "25ms",
            "loss": "0.3%",
            "limit": 2048
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "140mbit",
            "delay": "55ms",
            "jitter": "20ms",
            "loss": "0.6%",
            "limit": 2048
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "90mbit",
            "delay": "80ms",
            "jitter": "30ms",
            "loss": "0.8%",
            "limit": 2048
          }
        }
      ]
    },
    "normal-saturated": {
      "description": "Three shaped paths with realistic queues so overload can show latency, backlog, and drops.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "3.2mbit"
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "2mbit"
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "5mbit"
          }
        }
      ]
    },
    "forced-drop": {
      "description": "Same shaped rates with tight queues so over-capacity tests report visible drops quickly.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "3.2mbit",
            "limit": 32
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "2mbit",
            "limit": 20
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "5mbit",
            "limit": 40
          }
        }
      ]
    },
    "latency-jitter-skew": {
      "description": "Low-latency path-a, moderate path-b, and high-jitter path-c for reorder testing.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "3.2mbit",
            "delay": "10ms",
            "jitter": "2ms"
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "2mbit",
            "delay": "45ms",
            "jitter": "8ms"
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "5mbit",
            "delay": "120ms",
            "jitter": "35ms"
          }
        }
      ]
    },
    "loss-on-fast-path": {
      "description": "Path-a is still low latency but lossy, useful for loss-aware policy checks.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "3.2mbit",
            "delay": "10ms",
            "jitter": "2ms",
            "loss": "5%"
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "2mbit",
            "delay": "35ms"
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "5mbit",
            "delay": "55ms"
          }
        }
      ]
    },
    "wander-low": {
      "description": "Low-capacity step for three-path bandwidth cycling.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "2mbit",
            "limit": 24
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "1.2mbit",
            "limit": 16
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "3mbit",
            "limit": 32
          }
        }
      ]
    },
    "wander-mid": {
      "description": "Middle-capacity step for three-path bandwidth cycling.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "3.4mbit",
            "limit": 32
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "2mbit",
            "limit": 20
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "5mbit",
            "limit": 40
          }
        }
      ]
    },
    "wander-high": {
      "description": "High-capacity step for three-path bandwidth cycling.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "5mbit",
            "limit": 64
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "3mbit",
            "limit": 32
          }
        },
        {
          "path": "path-c",
          "side": "both",
          "shape": {
            "rate": "8mbit",
            "limit": 64
          }
        }
      ]
    }
  },
  "future_features": [
    "fixed-round-robin",
    "path-down-recovery",
    "netem-loss-jitter-reorder",
    "mtu-mismatch",
    "receiver-metrics",
    "ipv6-dual-path",
    "rust-backed-lab-forwarder"
  ]
}
