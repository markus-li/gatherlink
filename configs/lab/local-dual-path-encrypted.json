{
  "schema_version": 1,
  "name": "local-dual-path-encrypted",
  "scenario": "local-dual-path",
  "description": "Two unprivileged Gatherlink instances over two root-created simulated WAN paths with static AEAD transport enabled for lab validation.",
  "security": {
    "mode": "static",
    "receiver_index": 1,
    "send_key": "ERERERERERERERERERERERERERERERERERERERERERE=",
    "receive_key": "IiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiI="
  },
  "runtime_dir": ".lab/local-dual-path-encrypted",
  "nodes": [
    {
      "name": "client",
      "role": "client",
      "config_path": "configs/examples/minimal-client.json",
      "run_as": "current-user"
    },
    {
      "name": "server",
      "role": "server",
      "config_path": "configs/examples/minimal-server.json",
      "run_as": "current-user"
    }
  ],
  "paths": [
    {
      "name": "path-a",
      "family": "ipv4",
      "client_address": "10.80.1.1",
      "server_address": "10.80.1.2",
      "subnet": "10.80.1.0/30",
      "default_max_speed": "50mbit",
      "shape": {
        "rate": "50mbit"
      }
    },
    {
      "name": "path-b",
      "family": "ipv4",
      "client_address": "10.80.2.1",
      "server_address": "10.80.2.2",
      "subnet": "10.80.2.0/30",
      "default_max_speed": "50mbit",
      "shape": {
        "rate": "50mbit"
      }
    }
  ],
  "traffic": {
    "generator": "iperf3",
    "listen": "127.0.0.1:55180",
    "target": "127.0.0.1:51820",
    "duration_seconds": 10,
    "bandwidth": "20mbit"
  },
  "reorder_policies": [
    {
      "node_pair": "client<->server",
      "max_hold": "150ms"
    }
  ],
  "profiles": {
    "clean": {
      "path-a": {
        "state": "up"
      },
      "path-b": {
        "state": "up"
      }
    },
    "rate-10mbit": {
      "path-a": {
        "rate": "10mbit"
      },
      "path-b": {
        "rate": "10mbit"
      }
    },
    "lossy-path-a": {
      "path-a": {
        "loss": "5%"
      }
    },
    "slow-lossy-path-b": {
      "path-b": {
        "rate": "2mbit",
        "delay": "80ms",
        "jitter": "20ms",
        "loss": "3%"
      }
    },
    "mtu-1200": {
      "path-a": {
        "mtu": 1200
      },
      "path-b": {
        "mtu": 1200
      }
    },
    "path-a-down": {
      "path-a": {
        "state": "down"
      }
    },
    "path-b-blackhole": {
      "path-b": {
        "blackhole": true
      }
    }
  },
  "network_modes": {
    "normal-saturated": {
      "description": "Normal saturated-link behavior: shaped rates with the default qdisc queue so overload can appear as latency, backlog, reordering, and eventual drops like a real interface.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "3.2mbit"
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "1.7mbit"
          }
        }
      ]
    },
    "forced-drop": {
      "description": "Stress-test behavior: same shaped rates with tight qdisc queues so sustained over-capacity traffic quickly reports visible drops.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "3.2mbit",
            "limit": 32
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "1.7mbit",
            "limit": 16
          }
        }
      ]
    },
    "latency-jitter-skew": {
      "description": "Scheduler pressure behavior: keep both paths usable but make path-b slower and jittery so out-of-order and reorder pressure are visible.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "3.2mbit",
            "delay": "10ms",
            "jitter": "2ms"
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "1.7mbit",
            "delay": "90ms",
            "jitter": "25ms"
          }
        }
      ]
    },
    "wander-low": {
      "description": "Low-capacity step for cycling bandwidth while traffic is running.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "2.2mbit",
            "limit": 32
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "1.2mbit",
            "limit": 16
          }
        }
      ]
    },
    "wander-mid": {
      "description": "Middle-capacity step for cycling bandwidth while traffic is running.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "3.4mbit",
            "limit": 32
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "1.9mbit",
            "limit": 16
          }
        }
      ]
    },
    "wander-high": {
      "description": "High-capacity step for cycling bandwidth while traffic is running.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "5mbit",
            "limit": 64
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "3mbit",
            "limit": 32
          }
        }
      ]
    },
    "clean-50mbit": {
      "description": "Restore the default clean lab rates with ordinary qdisc queueing.",
      "targets": [
        {
          "path": "path-a",
          "side": "both",
          "shape": {
            "rate": "50mbit"
          }
        },
        {
          "path": "path-b",
          "side": "both",
          "shape": {
            "rate": "50mbit"
          }
        }
      ]
    }
  },
  "future_features": [
    "fixed-round-robin",
    "path-down-recovery",
    "netem-loss-jitter-reorder",
    "mtu-mismatch",
    "receiver-metrics",
    "ipv6-dual-path"
  ]
}
