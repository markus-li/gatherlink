# Gatherlink real-VM acceptance inventory template.
#
# Copy this file to an ignored location such as:
#   .gatherlink/vm-acceptance/inventory.env
#
# Do not put private keys, passwords, or personal hostnames in committed files.

NODE_A_SSH="debian-vm-a"
NODE_B_SSH="debian-vm-b"

REMOTE_WORKDIR="~/gatherlink-v0.9-acceptance"
REMOTE_CONFIG_DIR="~/gatherlink-v0.9-acceptance/configs"
REMOTE_REPORT_DIR="~/gatherlink-v0.9-acceptance/report"

NODE_A_SERVICE_NAME="vm.node-a"
NODE_B_SERVICE_NAME="vm.node-b"

NODE_A_SERVICE_LISTEN="10.90.0.11:55180"
NODE_A_SERVICE_TARGET="10.90.0.12:51820"
NODE_B_SERVICE_LISTEN="0.0.0.0:0"
NODE_B_SERVICE_TARGET="10.90.0.12:51820"

PATH_A_NODE_A_BIND="10.90.1.11:56001"
PATH_A_NODE_B_BIND="10.90.1.12:57001"
PATH_B_NODE_A_BIND="10.90.2.11:56002"
PATH_B_NODE_B_BIND="10.90.2.12:57002"

PATH_A_INTERFACE="eth1"
PATH_B_INTERFACE="eth2"
PATH_MTU="1200"
PATH_CAPACITY_BPS="50000000"

# Authenticated mode is the v0.9-facing secure config path. These committed
# example session keys are valid enough for dry-run config validation, but
# run_acceptance.sh refuses --execute until they are replaced with generated
# material.
NODE_A_RECEIVER_INDEX="101"
NODE_A_SEND_KEY="ERERERERERERERERERERERERERERERERERERERERERE="
NODE_A_RECEIVE_KEY="IiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiI="
NODE_B_RECEIVER_INDEX="101"
NODE_B_SEND_KEY="IiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiI="
NODE_B_RECEIVE_KEY="ERERERERERERERERERERERERERERERERERERERERERE="
