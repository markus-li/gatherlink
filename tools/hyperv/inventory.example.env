# Gatherlink Hyper-V VM acceptance inventory.
#
# Copy to an ignored path such as:
#   .gatherlink/hyperv-vm-acceptance/inventory.env
#
# Do not commit real host-key fingerprints if you consider them host-local, and
# never commit private keys, passwords, or personal hostnames.

HYPERV_VM_A="gatherlink-vm-a"
HYPERV_VM_B="gatherlink-vm-b"
HYPERV_VM_C="gatherlink-vm-c"

# Optional when the runner can use the Hyper-V PowerShell resolver. Set these to
# make the Bash runner independent of PowerShell after the VMs are already known.
HYPERV_VM_A_IP=""
HYPERV_VM_B_IP=""
HYPERV_VM_C_IP=""

HYPERV_VM_A_HOST_KEY="<vm-a-host-key-fingerprint>"
HYPERV_VM_B_HOST_KEY="<vm-b-host-key-fingerprint>"
HYPERV_VM_C_HOST_KEY="<vm-c-host-key-fingerprint>"

HYPERV_BRANCH="main"
HYPERV_ACCEPTANCE_COUNT="5"
HYPERV_ACCEPTANCE_DURATION="30"
HYPERV_ACCEPTANCE_INTERVAL="0.01"
HYPERV_ACCEPTANCE_PAYLOAD_SIZE="512"
HYPERV_ACCEPTANCE_SHAPE_PROFILE="asymmetric"
HYPERV_ACCEPTANCE_MIN_DELIVERY_RATIO="0.90"
